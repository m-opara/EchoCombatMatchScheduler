{
  "name": "echo-combat-match-scheduler",
  "version": "1.0.0",
  "description": "A Discord scheduling bot for Echo Combat match planning.",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "commands:register": "tsx src/registerCommands.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "discord.js": "^14.21.0",
    "dotenv": "^16.4.7",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.2",
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "prisma": "^6.10.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  }
}
